generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "mysql"
}

model User {
  id                 String        @id
  name               String
  email              String        @unique
  emailVerified      Boolean
  image              String?
  createdAt          DateTime
  updatedAt          DateTime
  address            String?       @default("")
  phone              String?       @default("")
  status             Boolean       @default(false)
  timeZone           String?
  stripe_customer_id String?
  times              Json
  rating             Int           @default(0)
  role               Role          @default(USER)
  latitude           Float?
  longitude          Float?
  slug               String?       @unique
  accounts           Account[]
  appointment        appointment[]
  reminder           reminder[]
  services            service[]
  sessions           Session[]
  staff              Staff[]
  subscription       subscription?

  @@map("user")
}

model Staff {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  image       String?
  times       Json
  status      Boolean       @default(true)
  userId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  appointment appointment[]
  user        User          @relation(fields: [userId], references: [id])
  services     service[]     @relation("staffservices")

  @@index([userId], map: "staff_userId_fkey")
  @@map("staff")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_fkey")
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "account_userId_fkey")
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model appointment {
  id              String   @id
  name            String
  email           String
  phone           String
  appointmentDate DateTime
  time            String
  serviceId       String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  staffId         String?
  service         service  @relation(fields: [serviceId], references: [id], map: "Appointment_serviceId_fkey")
  staff           Staff?   @relation(fields: [staffId], references: [id], map: "Appointment_staffId_fkey")
  user            User     @relation(fields: [userId], references: [id], map: "Appointment_userId_fkey")

  @@index([serviceId], map: "Appointment_serviceId_fkey")
  @@index([staffId], map: "Appointment_staffId_fkey")
  @@index([userId], map: "Appointment_userId_fkey")
}

model reminder {
  id          String   @id
  description String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        User     @relation(fields: [userId], references: [id], map: "Reminder_userId_fkey")

  @@index([userId], map: "Reminder_userId_fkey")
}

model service {
  id          String        @id
  name        String
  price       Int
  duration    Int
  status      Boolean       @default(true)
  userId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  appointment appointment[]
  user        User          @relation(fields: [userId], references: [id], map: "Service_userId_fkey")
  staff       Staff[]       @relation("staffservices")

  @@index([userId], map: "Service_userId_fkey")
}

model subscription {
  id        String            @id
  status    String
  plan      subscription_plan
  priceId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime
  userId    String            @unique(map: "Subscription_userId_key")
  user      User              @relation(fields: [userId], references: [id], map: "Subscription_userId_fkey")
}

enum Role {
  USER
  ADMIN
}

enum subscription_plan {
  BASIC
  PLUS
  PROFESSIONAL
}
